default_platform(:android)

platform :android do

  private_lane :release_to_play do |options|
    track = options[:track]

    # Build release APK for local/device testing (no version bump here).
    gradle(
      task: "assemble",
      build_type: "Release",
      flags: "--no-configuration-cache",
      print_command: false
    )

    # Build release AAB for Play upload (triggers bundleRelease/version bump).
    gradle(
      task: "bundle",
      build_type: "Release",
      flags: "--no-configuration-cache",
      print_command: false
    )

    git_commit(
      path: "version.properties",
      message: "chore: bump versionCode [fastlane]"
    )
    push_to_git_remote

    upload_to_play_store(
      track: track,
      aab: lane_context[SharedValues::GRADLE_AAB_OUTPUT_PATH],
      mapping: lane_context[SharedValues::GRADLE_MAPPING_TXT_OUTPUT_PATH],
      skip_upload_apk: true,
      skip_upload_metadata: true,
      skip_upload_changelogs: true,
      skip_upload_images: true,
      skip_upload_screenshots: true
    )
  end

  # ─── fastlane closed ────────────────────────────────────────────────────────
  # Full release flow in one command:
  #   1. bundleRelease (auto-increments versionCode via Gradle task)
  #   2. Commits version.properties and pushes to git
  #   3. Uploads AAB + R8 mapping to Closed testing (Alpha)
  desc "Build, bump version, push to git, upload to Closed testing (Alpha)"
  lane :closed do
    release_to_play(track: "alpha")
  end

  # ─── fastlane production ───────────────────────────────────────────────────
  # Same flow as closed, but uploads to the production track.
  desc "Build, bump version, push to git, upload to Production"
  lane :production do
    release_to_play(track: "production")
  end

  # ─── fastlane test ──────────────────────────────────────────────────────────
  desc "Run unit tests"
  lane :test do
    gradle(task: "test")
  end

end
