default_platform(:android)

platform :android do

  private_lane :release_to_play do |options|
    track = options[:track]

    # Build release APK for local/device testing (no version bump here).
    gradle(
      task: "assemble",
      build_type: "Release",
      flags: "--no-configuration-cache",
      print_command: false
    )

    # Build release AAB for Play upload (triggers bundleRelease/version bump).
    gradle(
      task: "bundle",
      build_type: "Release",
      flags: "--no-configuration-cache",
      print_command: false
    )

    upload_to_play_store(
      track: track,
      aab: lane_context[SharedValues::GRADLE_AAB_OUTPUT_PATH],
      mapping: lane_context[SharedValues::GRADLE_MAPPING_TXT_OUTPUT_PATH],
      skip_upload_apk: true,
      skip_upload_metadata: true,
      skip_upload_changelogs: false,
      skip_upload_images: true,
      skip_upload_screenshots: true
    )

    git_commit(
      path: "version.properties",
      message: "chore: bump versionCode [fastlane]"
    )
    push_to_git_remote
  end

  desc "Retry Play upload for existing release artifacts without rebuilding/bumping"
  lane :retry_production_upload do
    upload_to_play_store(
      track: "production",
      aab: "app/build/outputs/bundle/release/app-release.aab",
      mapping: "app/build/outputs/mapping/release/mapping.txt",
      skip_upload_apk: true,
      skip_upload_metadata: true,
      skip_upload_changelogs: false,
      skip_upload_images: true,
      skip_upload_screenshots: true
    )
  end

  # ─── fastlane internal ─────────────────────────────────────────────────────
  # Build release APK and upload only APK to Google Play Internal App Sharing.
  desc "Build release APK and upload to Internal App Sharing (APK only)"
  lane :internal do
    gradle(
      task: "assemble",
      build_type: "Release",
      flags: "--no-configuration-cache",
      print_command: false
    )

    upload_to_play_store_internal_app_sharing(
      apk: "app/build/outputs/apk/release/app-release.apk"
    )
  end

  # ─── fastlane closed ────────────────────────────────────────────────────────
  # Full release flow in one command:
  #   1. bundleRelease (auto-increments versionCode via Gradle task)
  #   2. Commits version.properties and pushes to git
  #   3. Uploads AAB + R8 mapping to Closed testing (Alpha)
  desc "Build, bump version, push to git, upload to Closed testing (Alpha)"
  lane :closed do
    release_to_play(track: "alpha")
  end

  # ─── fastlane production ───────────────────────────────────────────────────
  # Same flow as closed, but uploads to the production track.
  desc "Build, bump version, push to git, upload to Production"
  lane :production do
    release_to_play(track: "production")
  end

  # ─── fastlane test ──────────────────────────────────────────────────────────
  desc "Run unit tests"
  lane :test do
    gradle(task: "test")
  end

end
